# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Buckets S3 ────────────────────────────────────────────────────────────────
# Input (somente leitura — propriedade do bcb-pipeline)
BCB_STAGING_BUCKET=bcb-pipeline-staging

# Output (propriedade do bcb-warehouse)
BCB_WAREHOUSE_BUCKET=bcb-warehouse

# ── Glue ──────────────────────────────────────────────────────────────────────
GLUE_JOB_NAME=bcb-staging-transform
GLUE_TEMP_DIR=s3://bcb-warehouse/glue/temp
GLUE_SCRIPTS_DIR=s3://bcb-warehouse/glue/scripts

# ── Athena ────────────────────────────────────────────────────────────────────
ATHENA_DATABASE=bcb_warehouse
ATHENA_WORKGROUP=primary
ATHENA_RESULTS_LOCATION=s3://bcb-warehouse/athena-results

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROFILES_DIR=dbt/bcb_warehouse
DBT_TARGET=dev

# ── Airflow ───────────────────────────────────────────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
